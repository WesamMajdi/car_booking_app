<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/filter_options"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/price_range"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.slider.RangeSlider
        android:id="@+id/slider_price"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:valueFrom="0"
        android:valueTo="500"
        android:stepSize="10"
        app:values="@array/initial_slider_values"
        android:layout_marginBottom="16dp"/>

    <!-- Transmission -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/transmission"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_transmission"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        android:layout_marginBottom="16dp">
        
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_trans_any"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/any"
            android:checked="true"
            style="@style/Widget.MaterialComponents.Chip.Choice"/>
            
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_trans_auto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/automatic"
            style="@style/Widget.MaterialComponents.Chip.Choice"/>
            
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_trans_manual"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/manual"
            style="@style/Widget.MaterialComponents.Chip.Choice"/>
    </com.google.android.material.chip.ChipGroup>

    <!-- Fuel Type -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/fuel_type"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_fuel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        android:layout_marginBottom="16dp">
        
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_fuel_any"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/any"
            android:checked="true"
            style="@style/Widget.MaterialComponents.Chip.Choice"/>
            
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_fuel_petrol"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/petrol"
            style="@style/Widget.MaterialComponents.Chip.Choice"/>
            
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_fuel_diesel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/diesel"
            style="@style/Widget.MaterialComponents.Chip.Choice"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_fuel_electric"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/electric"
            style="@style/Widget.MaterialComponents.Chip.Choice"/>
    </com.google.android.material.chip.ChipGroup>

    <!-- Seats -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/seats"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_seats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        android:layout_marginBottom="16dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_seats_any"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/any"
            android:checked="true"
            style="@style/Widget.MaterialComponents.Chip.Choice"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_seats_4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4+"
            style="@style/Widget.MaterialComponents.Chip.Choice"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_seats_5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5+"
            style="@style/Widget.MaterialComponents.Chip.Choice"/>
            
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_seats_7"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="7+"
            style="@style/Widget.MaterialComponents.Chip.Choice"/>
    </com.google.android.material.chip.ChipGroup>

    <!-- Year -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/year"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_year"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        android:layout_marginBottom="24dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_year_any"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/any"
            android:checked="true"
            style="@style/Widget.MaterialComponents.Chip.Choice"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_year_2020"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2020+"
            style="@style/Widget.MaterialComponents.Chip.Choice"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_year_2022"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2022+"
            style="@style/Widget.MaterialComponents.Chip.Choice"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_year_2023"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2023+"
            style="@style/Widget.MaterialComponents.Chip.Choice"/>
    </com.google.android.material.chip.ChipGroup>

    <!-- Availability -->
    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_available_only"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/available_only"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_apply_filter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/apply_filters"
        android:padding="12dp"/>

</LinearLayout>
